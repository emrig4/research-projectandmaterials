{
    "name": "ci/laravel",
    "type": "project",
    "description": "The Cynoinfotech eBook System.",
    "license": "MIT",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/airondev/pcloud-laravel"
        }
    ],
    "require": {
        "php": ">=7.2.19|^8.0",
        "ext-intl": "^7.4",
        "airondev/pcloud-laravel": "dev-main",
        "artisansweb/image-optimizer": "^0.0.5",
        "binshops/laravel-blog": "v8.1.2",
        "buzz/laravel-google-captcha": "^2.3",
        "cache/filesystem-adapter": "^1.0",
        "doctrine/dbal": "^2.10",
        "fideloper/proxy": "^4.0",
        "fruitcake/laravel-cors": "^2.0",
        "fzaninotto/faker": "^1.9.1",
        "guzzlehttp/guzzle": "^6.5",
        "jackiedo/dotenv-editor": "^1.0",
        "kingflamez/laravelrave": "^3.0",
        "laravel/framework": "^7.0",
        "laravel/helpers": "^1.2",
        "laravel/tinker": "^2.0",
        "mews/purifier": "^3.1",
        "nikhiltester/stylist": "^1.0",
        "nwidart/laravel-modules": "^6.0",
        "rtconner/laravel-tagging": "^4.0",
        "spatie/laravel-sitemap": "5.7",
        "swayok/alternative-laravel-cache": "^5.4",
        "symfony/intl": "^5.0",
        "unicodeveloper/laravel-paystack": "^1.0",
        "wikimedia/composer-merge-plugin": "^2.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.0",
        "beyondcode/laravel-dump-server": "^1.0",
        "beyondcode/laravel-query-detector": "^1.0",
        "filp/whoops": "^2.0",
        "mockery/mockery": "^1.3.1",
        "nunomaduro/collision": "^4.1",
        "facade/ignition": "^2.0",
        "phpunit/phpunit": "^8.5"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "7.2.19"
        },
        "allow-plugins": {
            "wikimedia/composer-merge-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "nwidart/laravel-modules"
            ]
        },
        "merge-plugin": {
            "require": [
                "Modules/*/composer.json"
            ],
            "merge-extra": true,
            "merge-extra-deep": true,
            "merge-scripts": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/",
            "Themes\\": "Themes/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "post-install-cmd": [
            "php artisan clear-compiled",
            "chmod -R 777 public/",
            "ln -sr storage/app/public public/storage"
        ]
    }
}
